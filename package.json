{
  "name": "oop",
  "version": "1.0.0",
  "description": "Project implementing OOP concepts.",
  "main": "index.js",
  "verbose": true,
  "ignore": [],
  "baseUrl": "./src",
  "watch": [
    "src/**/*.ts"
  ],
  "execMap": {
    "ts": "node --inspect=0.0.0.0:9229 --nolazy -r ts-node/register"
  },
